# ─────────────────────────────────────────────────────────────────────────────
# ShadowSpace Node SDK — environment configuration
# Copy this file to `.env` (which is gitignored) and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Program address (OPTIONAL) ───────────────────────────────────────────────
# The SDK ships the program id inside its bundled IDL (DEFAULT_PROGRAM_ID =
# IDL.address, kept in lockstep with the program by `anchor keys sync`), so you do
# NOT need to set this. Leave it unset to use the deployment the SDK was built for.
# Set it only to REPOINT the SDK at a different deployment (e.g. a fork, or a clean
# redeploy under a new id) without rebuilding/re-syncing the IDL.
# SOLANA_PDA_ADDRESS=

# ── REQUIRED: signer wallet ──────────────────────────────────────────────────
# The keypair the SDK signs and pays with. No wallet is created — this is enough.
# Accepts ANY of these formats:
#   • base58 secret key (what Phantom "Export Private Key" / most tools give you)
#   • hex secret key — 128 hex chars (64-byte) or 64 hex chars (32-byte seed), 0x optional
#   • a JSON byte array (what `solana-keygen` / `~/.config/solana/id.json` give you)
PRIVATE_KEY=your_base58_or_hex_secret_key_or_[1,2,3,...]_json_array

# ── Cluster switch ───────────────────────────────────────────────────────────
# The single switch that flips RPC + keyless fallback between mainnet and devnet.
#   IS_MAINNET=true  → mainnet-beta
#   IS_MAINNET=false → devnet  (default)
IS_MAINNET=false

# Treasury that receives rent refunds on account-close instructions. Must match
# the program's hard-coded treasury; only change it if the program was forked.
# SOLANA_TREASURY_ADDRESS=BYNtxb7zMereaMrmMcWCQx3G6Y1KZspnMJbiuqoh9MrF

# Default commitment for reads/writes (processed | confirmed | finalized).
# SOLANA_COMMITMENT=confirmed

# ── RPC providers (failover pool) ────────────────────────────────────────────
# JUST INSERT THE API KEYS YOU HAVE — the SDK does the rest. It assembles an
# ordered failover pool from whichever keys are set (gated by IS_MAINNET) and
# automatically picks/rotates providers, failing over when one is blocked /
# rate-limited / stale. You never select a provider by hand; add a key and it
# joins the pool, remove it and it drops out. No code change needed.
#
# Priority order (each line included only if its key is present):
#   RPC_NODE_URL (if set)  →  keyed providers below  →  keyless public fallback
# On DEVNET only Helius applies; the mainnet-only keys below are ignored there.
# A keyed endpoint needs its key IN the URL — a bare provider URL will 401, so
# prefer the dedicated *_API_KEY vars over hand-writing RPC_NODE_URL.
#
# Optional: pin ONE explicit endpoint (your own node / a different provider).
# Leave blank to let the keyed providers below drive the pool. Include any auth.
RPC_NODE_URL=

# Helius — works on BOTH clusters with the same key (devnet + mainnet endpoints).
# Set this and you're done: it becomes the pool's primary, with the keyless
# public endpoint as the automatic fallback.
HELIUS_API_KEY=

# Mainnet-only secondaries (ignored on devnet). All optional — add what you have
# and they slot into the failover order automatically.
FLUX_API_KEY=
ALCHEMY_SOLANA_KEY=
QUICKNODE_SOLANA_URL=
SYNDICA_SOLANA_KEY=
DRPC_SOLANA_URL=

# Keyless last-resort RPC overrides (sensible defaults already baked in).
# RPC_PUBLIC_FALLBACK=https://solana-rpc.publicnode.com
# RPC_DEVNET_FALLBACK=https://api.devnet.solana.com

# ── RPC pool tuning (all optional) ───────────────────────────────────────────
# RPC_TIMEOUT_MS=8000
# RPC_BREAKER_THRESHOLD=3
# RPC_BREAKER_COOLDOWN_MS=60000
# RPC_UPSTREAM_RPS=25
# RPC_UPSTREAM_CONCURRENCY=8
# RPC_SLOT_LAG_THRESHOLD=150
